  <script>
    // Toggle menu mobile
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Scroll animation
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute('href')).scrollIntoView({
          behavior: 'smooth'
        });
      });
    });

    // Atualizar o ano no footer
    document.getElementById('year').textContent = new Date().getFullYear();

    // Botão "Voltar ao topo"
    const scrollTop = document.getElementById('scrollTop');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) {
        scrollTop.classList.add('show');
      } else {
        scrollTop.classList.remove('show');
      }
    });

    scrollTop.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });

    // Tema claro/escuro
    const themeToggle = document.getElementById('theme-toggle');
    const themeIconSun = document.getElementById('theme-icon-sun');
    const themeIconMoon = document.getElementById('theme-icon-moon');
    const logoAs = document.getElementById('logoAs');

    // Verificar tema salvo no localStorage ou preferência do sistema
    const savedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    if (savedTheme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      themeIconSun.classList.add('hidden');
      themeIconMoon.classList.remove('hidden');
      logoAs.src = "logo-black.png"
    }

    if (document.documentElement.getAttribute('data-theme') === 'dark') {
      logoAs.src = "logo-black.png"
    } else {
      logoAs.src = "logo-white.png"

    }

    themeToggle.addEventListener('click', () => {
      if (document.documentElement.getAttribute('data-theme') === 'dark') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
        themeIconSun.classList.remove('hidden');
        themeIconMoon.classList.add('hidden');
        logoAs.src = "logo-white.png"
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
        themeIconSun.classList.add('hidden');
        themeIconMoon.classList.remove('hidden');
        logoAs.src = "logo-black.png"
      }
    });

    // Carregar posts
    document.addEventListener('DOMContentLoaded', function () {
      loadPosts();

      // Configurar formulário de contato
      document.getElementById('contact-form').addEventListener('submit', function (e) {
        e.preventDefault();
        alert('Mensagem enviada! Obrigado pelo contato.');
        this.reset();
      });

      // Configurar botão de carregar mais posts
      document.getElementById('load-more').addEventListener('click',()=>{
         window.location.href ="/blog"
      });
    });

    let currentPage = 1;
    const postsPerPage = 6;

 function formatDate(dateString) {
      const options = { year: 'numeric', month: 'short', day: 'numeric' };
      return new Date(dateString).toLocaleDateString('pt-BR', options);
    }

    async function loadPosts() {
      // Em um cenário real, isso viria de uma API
      const res = await fetch("/api/posts");
      const posts = await res.json();
      const postsContainer = document.getElementById('posts-container');
      const startIndex = (currentPage - 1) * postsPerPage;
      const endIndex = startIndex + postsPerPage;
      const postsToShow = posts.slice(startIndex, endIndex);
      console.log(posts)
      postsToShow.forEach(post => {
        console.log(post.status)
        const postElement = document.createElement('div');
        postElement.className = 'card p-6 animate__animated animate__fadeInUp';
        if (post.status == "published") {
          postElement.innerHTML = `
        <div class="mb-4 overflow-hidden rounded-lg">
            <img src="${post.image}" alt="${post.title}" class="w-full h-48 object-cover transition-transform duration-300 hover:scale-110">
          </div>
          <div class="text-sm text-primary mb-2">${formatDate(post.createdAt)}</div>
          <h3 class="text-xl font-bold mb-3 text-custom-primary">${post.title}</h3>
          <p class="text-custom-secondary mb-4">${post.description}</p>
          <a href="/post?id=${post.id}" class="text-primary hover:text-secondary font-medium inline-flex items-center">
            Ler mais
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        `;
        postsContainer.appendChild(postElement);
        }
        
      });

      
    }

    function loadMorePosts() {
      currentPage++;
      loadPosts();
    }

    // Animação de entrada dos elementos
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate__fadeInUp');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1
    });

    document.querySelectorAll('.animate__animated').forEach(el => {
      observer.observe(el);
    });


    // Configurar modal de cookies
    const cookieSettingsModal = document.getElementById('cookie-settings-modal');
    const openCookieSettings = document.getElementById('open-cookie-settings');
    const closeSettings = document.getElementById('close-settings');
    const saveSettings = document.getElementById('save-settings');
    const Privacidade = document.getElementById('Privacidade')

    if (localStorage.getItem('cookiePreferences') == undefined) {
      cookieSettingsModal.classList.remove('hidden')
    }

    Privacidade.addEventListener('click', () => {
      window.location.href = "/privacidade"
    });
    closeSettings.addEventListener('click', () => {
      cookieSettingsModal.classList.add('hidden');
    });
    saveSettings.addEventListener('click', () => {
      // Salvar preferências de cookies
      const performanceCookies = document.getElementById('performance-cookies').checked;
      const marketingCookies = document.getElementById('marketing-cookies').checked;

      localStorage.setItem('cookiePreferences', JSON.stringify({
        performance: performanceCookies,
        marketing: marketingCookies,
        essential: true // Sempre verdadeiro
      }));

      cookieSettingsModal.classList.add('hidden');
      // alert('Preferências de cookies salvas com sucesso!');
    });

    // Configurar toggles de cookies
    const toggles = document.querySelectorAll('input[type="checkbox"]:not(:disabled)');
    toggles.forEach(toggle => {
      const label = toggle.nextElementSibling;
      const switchElement = label.nextElementSibling;

      toggle.addEventListener('change', () => {
        if (toggle.checked) {
          switchElement.style.transform = 'translateX(24px)';
          label.style.backgroundColor = 'var(--primary)';
        } else {
          switchElement.style.transform = 'translateX(0)';
          label.style.backgroundColor = '#d1d5db';
        }
      });

      // Inicializar estado dos toggles
      if (toggle.checked) {
        switchElement.style.transform = 'translateX(24px)';
        label.style.backgroundColor = 'var(--primary)';
      }
    });

  </script>
</body>

</html>